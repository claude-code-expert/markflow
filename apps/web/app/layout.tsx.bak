export default function RootLayout({ children }: { children: React.ReactNode }) {
  return (
    <html
      lang="ko"
      className={`${dmSans.variable} ${sora.variable} ${jetbrainsMono.variable} antialiased`}
    >
      <body>
        <Providers>
          {children}
          <ToastProvider />
          <DevAgentation />
        </Providers>
      </body>

/* ─── Toolbar styles ──────────────────────────────────────────────────────── */

.mf-toolbar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 2px;
  padding: 6px 8px;
  border-bottom: 1px solid var(--mf-toolbar-border);
  background: var(--mf-toolbar-bg);
  user-select: none;
}

.mf-toolbar-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: var(--mf-toolbar-btn-size);
  height: var(--mf-toolbar-btn-size);
  border-radius: 4px;
  border: 1px solid var(--mf-border-color);
  background: var(--mf-bg-primary);
  color: var(--mf-text-primary);
  cursor: pointer;
  transition: background-color 100ms, border-color 100ms;
  padding: 0;
  font-size: 12px;
  line-height: 1;
}

.mf-toolbar-btn:hover {
  background: var(--mf-btn-hover-bg);
}

.mf-toolbar-btn:focus-visible {
  outline: none;
  box-shadow: var(--mf-focus-ring);
}

.mf-toolbar-btn-active {
  background: var(--mf-btn-active-bg);
  border-color: var(--mf-btn-active-border);
  color: var(--mf-btn-active-text);
}

.mf-toolbar-btn-active:hover {
  background: var(--mf-btn-active-bg);
}

.mf-toolbar-sep {
  width: 1px;
  height: 20px;
  background: var(--mf-border-color);
  margin: 0 4px;
  align-self: center;
}

.mf-toolbar-spacer {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 4px;
}

/* ─── Preview pane Markdown rendered HTML styles ──────────────────────────── */
/* These must be global (not CSS Module) because they target dangerouslySetInnerHTML output */

@import 'katex/dist/katex.min.css';
@import 'highlight.js/styles/github.css';

.mf-preview {
  font-family: var(--mf-font-body);
  color: var(--mf-color-text);
  line-height: var(--mf-line-height);
}

.mf-preview h1,
.mf-preview h2,
.mf-preview h3,
.mf-preview h4,
.mf-preview h5,
.mf-preview h6 {
  color: var(--mf-color-heading);
  font-weight: var(--mf-heading-font-weight, 700);
  margin-top: 1.5em;
  margin-bottom: 0.5em;
  line-height: 1.25;
}

.mf-preview h1 {
  font-size: var(--mf-h1-font-size, 2em);
  color: var(--mf-h1-color, var(--mf-color-heading));
  background: var(--mf-h1-bg, transparent);
  padding: var(--mf-h1-padding, 0 0 0.3em 0);
  border-bottom: 2px solid var(--mf-color-hr);
  border-radius: var(--mf-h1-radius, 0);
}

.mf-preview h2 {
  font-size: var(--mf-h2-font-size, 1.5em);
  color: var(--mf-h2-color, var(--mf-color-heading));
  background: var(--mf-h2-bg, transparent);
  padding: var(--mf-h2-padding, 0 0 0.2em 0);
  border-bottom: 1px solid var(--mf-color-hr);
  border-radius: var(--mf-h2-radius, 0);
}

.mf-preview h3 {
  font-size: var(--mf-h3-font-size, 1.25em);
  color: var(--mf-h3-color, var(--mf-color-heading));
  background: var(--mf-h3-bg, transparent);
  padding: var(--mf-h3-padding, 0);
  border-radius: var(--mf-h3-radius, 0);
}

.mf-preview h4 {
  font-size: var(--mf-h4-font-size, 1.1em);
  color: var(--mf-h4-color, var(--mf-color-heading));
  background: var(--mf-h4-bg, transparent);
}
.mf-preview p  { margin: 0.75em 0; }

.mf-preview a {
  color: var(--mf-color-link);
  text-decoration: var(--mf-link-decoration, underline);
  text-underline-offset: 2px;
}
.mf-preview a:hover {
  color: var(--mf-color-link-hover, var(--mf-color-link));
}

.mf-preview :not(pre) > code {
  background: var(--mf-color-code-bg);
  color: var(--mf-color-code-text);
  padding: 0.15em 0.4em;
  border-radius: 4px;
  font-family: var(--mf-font-mono);
  font-size: 0.875em;
}

.mf-preview pre {
  background: var(--mf-color-pre-bg);
  border: 1px solid var(--mf-color-pre-border);
  border-radius: 8px;
  padding: 1em 1.25em;
  overflow-x: auto;
  margin: 1em 0;
}

.mf-preview pre code {
  background: none;
  color: inherit;
  padding: 0;
  font-size: 0.875em;
  font-family: var(--mf-font-mono);
}

.mf-preview blockquote {
  border-left: 4px solid var(--mf-color-blockquote-border);
  padding: 0.25em 0 0.25em 1em;
  margin: 1em 0;
  color: var(--mf-color-blockquote-text);
  font-style: italic;
}

.mf-preview blockquote > p { margin: 0; }

.mf-preview ul { padding-left: 1.5em; margin: 0.75em 0; list-style-type: disc; }
.mf-preview ol { padding-left: 1.5em; margin: 0.75em 0; list-style-type: decimal; }
.mf-preview ul.contains-task-list { list-style-type: none; padding-left: 0; }
.mf-preview li { margin: 0.25em 0; }

.mf-preview input[type='checkbox'] {
  margin-right: 0.4em;
  accent-color: var(--mf-accent);
}

.mf-preview table {
  width: 100%;
  border-collapse: collapse;
  margin: 1em 0;
  font-size: 0.9em;
}

.mf-preview th {
  background: var(--mf-color-table-header-bg);
  font-weight: 700;
  text-align: left;
  padding: 0.5em 0.75em;
  border: 1px solid var(--mf-color-table-border);
}

.mf-preview td {
  padding: 0.4em 0.75em;
  border: 1px solid var(--mf-color-table-border);
}

.mf-preview tr:hover td { background: var(--mf-color-table-hover); }

.mf-preview hr {
  border: none;
  border-top: 2px solid var(--mf-color-hr);
  margin: 2em 0;
}

.mf-preview img { max-width: 100%; border-radius: 6px; margin: 0.5em 0; }
.mf-preview del { opacity: 0.5; }

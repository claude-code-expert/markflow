# MarkFlow KMS 로컬 개발 환경 변수
# 이 파일은 gitignore에서 제외되어 레포에 포함됩니다.
# 프로덕션 시크릿은 절대 여기에 넣지 마세요.

# PostgreSQL (로컬)
DATABASE_URL=postgresql://markdown:password@localhost:5432/markdown_web

# JWT (개발용 — 프로덕션에서는 반드시 교체)
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-in-production

# 랜덤 문자열입니다. 터미널에서 생성:                                                                                              
                                               
# 방법 1: openssl                                                                                                                
# openssl rand -hex 32           



# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002     

# API 서버
HOST=0.0.0.0
PORT=4000
